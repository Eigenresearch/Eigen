eigen 1.0

qubit q0
qubit q1

# 1. Share Bell pair between Alice (q0) and Bob (q1)
H q0
CNOT q0, q1

# 2. Alice encodes two classical bits. Let's send the message "11"
# Bit 1 = 1 -> Apply Z to Alice's qubit q0
# Bit 2 = 1 -> Apply X to Alice's qubit q0
Z q0
X q0

# 3. Alice sends q0 to Bob. Bob decodes the state.
CNOT q0, q1
H q0

cbit c0
cbit c1
measure q0 -> c0
measure q1 -> c1

print c0
print c1

# Bob must successfully recover the encoded bits "11"
assert c0 == 1
assert c1 == 1
