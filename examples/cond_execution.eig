eigen 1.0

let angle: float = PI

qubit q0
qubit q1

# Setup q0 to be state |1>
X q0

cbit r0
measure q0 -> r0

# If we measured |1> on q0, apply X (using RX q1, PI) to q1
if r0 == 1 {
    RX q1, angle
}

cbit r1
measure q1 -> r1

print r0
print r1

# We expect both to be 1
assert r0 == 1
assert r1 == 1
