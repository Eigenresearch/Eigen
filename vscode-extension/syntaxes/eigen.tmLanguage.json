{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Eigen",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.eigen",
          "match": "\\b(if|else|while|for|in|break|continue|return|try|catch|throw)\\b"
        },
        {
          "name": "keyword.other.eigen",
          "match": "\\b(eigen|import|module|func|qfunc|struct|enum|let|noise|measure|trace|print|assert)\\b"
        },
        {
          "name": "support.type.eigen",
          "match": "\\b(int|float|string|bool|qubit|cbit|array|map)\\b"
        },
        {
          "name": "keyword.operator.eigen",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "support.function.quantum.eigen",
          "match": "\\b(H|X|Y|Z|S|T|RX|RY|RZ|CNOT|CZ|SWAP)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.eigen",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.eigen",
          "match": "\\\\."
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.eigen",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.eigen",
          "match": "//.*$"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.eigen",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.eigen",
          "match": "\\b\\d+\\b"
        }
      ]
    }
  ],
  "scopeName": "source.eigen"
}
