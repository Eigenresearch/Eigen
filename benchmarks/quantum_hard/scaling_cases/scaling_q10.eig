eigen 1.0

qubit q0
qubit q1
qubit q2
qubit q3
qubit q4
qubit q5
qubit q6
qubit q7
qubit q8
qubit q9
# GHZ staircase.
H q0
CNOT q0, q1
CNOT q0, q2
CNOT q0, q3
CNOT q0, q4
CNOT q0, q5
CNOT q0, q6
CNOT q0, q7
CNOT q0, q8
CNOT q0, q9
# Final Hadamard layer populates all 2^n amplitudes.
H q0
H q1
H q2
H q3
H q4
H q5
H q6
H q7
H q8
H q9
