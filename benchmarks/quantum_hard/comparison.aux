\@writefile{toc}{\contentsline {section}{\numberline {8}Scaling: runtime vs gate count (log-log)}{3}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {9}Accuracy error magnitude vs gate count}{3}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {10}Aggregate summary}{3}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Best-of-3 execution time per test. Log scale so the 1-2-qubit Bell tests ($\sim $40 µs) coexist in the same axes with the longest Trotter / random-circuit tests.}}{4}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Accuracy per test. Anything below the 99.9\,\% line fails the comparison. The bar is clamped to the 0-100.4\,\% window.}}{4}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces How speedups distribute across all 80 tests. A speedup $<1$ means numpy was faster than Eigen on that test; $>1$ means Eigen's Rust backend won.}}{4}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Quadrant (4-field matrix) of test cases. Horizontal axis: $\log _{10}$ of the gate count, vertical axis: number of qubits. Each \emph  {filled circle} is one PASS test labelled with its speedup (numpy ms $\div $ Eigen ms). \emph  {Hollow triangles} mark FAIL tests. Dashed lines split the four canonical strategy quadrants: micro (low-q/low-g), long horizontal (low-q/many-g), tall (many-q/low-g), and extreme (many-q/many-g). The medians are at $\log _{10} g = 1.15$ and $q = 3.0$.}}{5}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Log-log scaling of runtime vs gate count. A clean slope is the expected power-law $t \sim g^{\alpha }$ with $\alpha \approx 1$ in the regime where Python overhead per gate dominates over state-vector size work; a knee above $\sim $ 4-5 qubits reveals the denser matrix-vs-vector cost.}}{5}{}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Accuracy error magnitude $1-\textrm  {accuracy}$ vs gate count. The dashed horizontal line at $10^{-3}$ is the PASS threshold (99.9\,\%). All tests below the line pass; tests above it are flagged FAIL in the long table. The numerical floor at $\sim 10^{-15} \to 10^{-14}$ is dictated by double-precision unitary propagation; tests that hit it are essentially bit-identical to numpy.}}{6}{}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Aggregate summary across all 80 hard-quantum tests.}}{6}{}\protected@file@percent }
