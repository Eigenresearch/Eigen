\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Per-category aggregation: each row summarises one category of tests. Categories sorted by descending mean gate count (largest circuits first).}}{3}{}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4}Speed comparison (log scale)}{3}{}\protected@file@percent }
