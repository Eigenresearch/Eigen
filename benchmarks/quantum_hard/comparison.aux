\@writefile{toc}{\contentsline {section}{\numberline {2}Results (long multi-page table)}{1}{}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{Hard-quantum head-to-head over all 80 test cases. $Q$ = qubits, $g$ = gates, $d$=depth. \texttt  {PASS} requires accuracy $\ge 99.9\%$. \textbf  {80 pass / 0 fail}.}}{1}{}\protected@file@percent }
